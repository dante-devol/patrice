# Default: let Git normalize text line endings on commit.
* text=auto

# Shell scripts MUST keep LF — they run in Linux containers, and a CRLF shebang
# (`#!/bin/sh\r`) makes the kernel fail with "no such file or directory".
*.sh text eol=lf

# Windows-native script types stay CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
