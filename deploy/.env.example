# Patrice — production environment. Copy to `.env`, fill every CHANGE_ME, then
# `docker compose -f docker-compose.prod.yml up -d`.
#
# The API validates this on boot and FAILS FAST with an aggregate error listing
# every missing/invalid key (api/src/config/env.ts). Generate the secrets below
# with the commands in the comments — do not reuse the dev defaults.
#
# NOTE: Google / Discord OAuth client id + secret are NOT set here. They are
# runtime config, entered in the admin UI and stored encrypted in the database
# (ADR 0006); any DISCORD_CLIENT_* env is ignored.

# --- Image version to run -----------------------------------------------------
# Pin to a published release tag (recommended) rather than `latest`.
PATRICE_VERSION=latest
# Host port the web container listens on (plain HTTP). Your TLS proxy forwards here.
WEB_PORT=8080

# --- Required (boot fails without these) --------------------------------------
# Host `db` and the password must match the POSTGRES_* block below.
DATABASE_URL=postgresql://patrice:CHANGE_ME_DB_PASSWORD@db:5432/patrice?schema=public
# Public HTTPS origin users hit. Builds OAuth redirects and email links.
PUBLIC_BASE_URL=https://patrice.example.com
# >= 32 random bytes each.  Generate with:  openssl rand -base64 48
SESSION_SECRET=CHANGE_ME
TOKEN_PEPPER=CHANGE_ME
# Your real outbound mail server and the address Patrice sends from.
SMTP_URL=smtp://user:password@smtp.example.com:587
EMAIL_FROM=Patrice <no-reply@patrice.example.com>

# --- Behind a TLS-terminating proxy -------------------------------------------
NODE_ENV=production
COOKIE_SECURE=true
TRUST_PROXY=true
LOG_LEVEL=info

# --- Bundled Postgres credentials (consumed by the `db` service) --------------
# POSTGRES_PASSWORD must equal the password in DATABASE_URL above.
POSTGRES_USER=patrice
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=patrice

# --- Attachment storage -------------------------------------------------------
# `local` writes blobs to the patrice-storage volume (SINGLE-INSTANCE ONLY).
# For multi-instance / HA, switch to `s3` and fill the S3_* block.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./var/storage
# Max upload size in bytes (default 25 MiB).
# ATTACHMENT_MAX_BYTES=26214400
#
# STORAGE_DRIVER=s3
# S3_BUCKET=patrice
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.example.com   # MinIO / non-AWS endpoint
# S3_ACCESS_KEY_ID=CHANGE_ME
# S3_SECRET_ACCESS_KEY=CHANGE_ME
# S3_FORCE_PATH_STYLE=true             # required for MinIO

# --- Integrations (optional; Discord role-sync) -------------------------------
# AES-256-GCM key the worker uses to encrypt the stored Discord bot token.
# 64 hex chars.  Generate with:  openssl rand -hex 32
# Leave blank to disable encrypted integration tokens.
INTEGRATION_TOKEN_KEY=

# --- Optional tuning ----------------------------------------------------------
# Restore window (days) after retirement during which Revive is allowed.
# RETIREMENT_GRACE_DAYS=30
# Argon2 password-hash cost (raise on capable hardware).
# ARGON2_MEMORY_COST=19456
# ARGON2_TIME_COST=2
# ARGON2_PARALLELISM=1
