# Build context for `docker compose build web`. The Dockerfile runs `npm ci`
# and then `COPY . .`, so anything left here is copied into the build stage —
# excluding node_modules is a correctness fix (the host install is the wrong
# arch and would clobber the image's), not just a size one. (Docker reads this
# file from the build context root — ./web — so the repo-root .dockerignore
# does NOT apply to this build.)

# Dependencies — reinstalled with `npm ci` (host arch differs from the image).
node_modules/

# Angular build/compilation cache — machine-local, regenerated every build.
.angular/

# Build output — regenerated by `npm run build`.
dist/

# Screenshot/QA tooling — not part of the production bundle.
tools/
coverage/

# Secrets — never bake these into the context.
.env
.env.*
!.env.example

# Logs / OS / editor cruft.
*.log
.DS_Store
Thumbs.db

# Docker / VCS metadata — irrelevant to the build itself.
Dockerfile
.dockerignore
.git
.gitignore
