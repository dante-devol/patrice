# Patrice API — environment. Copy to .env and fill in. Validated on boot (fail-fast).
DATABASE_URL=postgresql://patrice:patrice@localhost:5432/patrice?schema=public
PUBLIC_BASE_URL=http://localhost:4200
SESSION_SECRET=change-me-32-bytes-minimum-secret
TOKEN_PEPPER=change-me-token-pepper-secret
SMTP_URL=smtp://localhost:1025
EMAIL_FROM=Patrice <no-reply@patrice.local>
LOG_LEVEL=info
NODE_ENV=development
COOKIE_SECURE=false
TRUST_PROXY=false
# Optional argon2 tuning
# ARGON2_MEMORY_COST=19456
# ARGON2_TIME_COST=2
# ARGON2_PARALLELISM=1
