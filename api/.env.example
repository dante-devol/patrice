# Patrice API — environment. Copy to .env and fill in. Validated on boot (fail-fast).
DATABASE_URL=postgresql://patrice:patrice@localhost:5432/patrice?schema=public
PUBLIC_BASE_URL=http://localhost:4200
SESSION_SECRET=change-me-32-bytes-minimum-secret
TOKEN_PEPPER=change-me-token-pepper-secret
SMTP_URL=smtp://localhost:1025
EMAIL_FROM=Patrice <no-reply@patrice.local>
LOG_LEVEL=info
NODE_ENV=development
COOKIE_SECURE=false
TRUST_PROXY=false
# Restore window (days) after retirement during which Revive is allowed.
RETIREMENT_GRACE_DAYS=30
# Object storage for attachments. `local` = on-disk (SINGLE-INSTANCE ONLY); `s3` =
# S3-compatible (AWS/MinIO), the production default, serving downloads via signed URLs.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./var/storage
ATTACHMENT_MAX_BYTES=26214400
# Required when STORAGE_DRIVER=s3:
# S3_BUCKET=patrice
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000   # MinIO / non-AWS endpoint
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_FORCE_PATH_STYLE=true            # required for MinIO
# Optional argon2 tuning
# ARGON2_MEMORY_COST=19456
# ARGON2_TIME_COST=2
# ARGON2_PARALLELISM=1
