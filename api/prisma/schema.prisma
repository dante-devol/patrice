// Patrice — Prisma schema (Slice 1).
//
// Conventions (docs/slices/00-overview.md):
//   - UUIDv7 PKs (PostgreSQL 18 `uuidv7()` default; see migration).
//   - timestamptz everywhere, UTC.
//   - Tenant tables carry organization_id (singleton org in v1).
//   - lifecycle_state + retired_at on core entities; FKs to core data ON DELETE RESTRICT.
//   - Some structures (citext columns, the partial bootstrap unique index, the
//     singleton CHECK) are hand-applied in the SQL migration — Prisma can't express them.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LifecycleState {
  active
  deactivated
  retired
}

enum AuthProvider {
  password
  google
}

enum AuthMethod {
  password
  google
}

enum RoleKind {
  standalone
  division
  team
}

enum GrantEffect {
  permit
  forbid
}

enum ScopeKind {
  global
  own
  own_division
  own_team
  specific_division
  specific_team
  role
}

enum UserRoleSource {
  patrice
  integration
}

enum AuthTokenKind {
  email_verification
  password_reset
}

enum ActivitySource {
  patrice
  integration
  system
}

enum QuestionType {
  detail_text
  multiline
  text
  numeric
  dropdown
  radio
  attachment
}

/// A task's rolled-up status (Slice 4 subset: open|claimed; review/revising/approved
/// arrive with submissions in Slice 5). Nullable until first computed at create time.
enum StatusCache {
  open
  claimed
  review
  revising
  approved
}

enum MessageKind {
  comment
  system
}

/// A submission's per-version review state (Slice 5). The lifecycle min-rule rolls
/// these up into a task's `status_cache`. `rejected` submissions are excluded from
/// the roll-up (set aside, no resubmit); a `revising` submission invites a resubmit
/// (a new row with the next `submission_no`).
enum SubmissionState {
  review
  revising
  approved
  rejected
}

enum AttachmentKind {
  image
  text
  audio
  model
  other
}

enum IntegrationProvider {
  discord
}

enum IntegrationStatus {
  active
  broken
  disabled
}

enum SyncDirection {
  inbound
  outbound
  bidirectional
}

model Organization {
  id            String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name          String
  settings      Json     @default("{}")
  configVersion BigInt   @default(0) @map("config_version")
  // Singleton guard column: always 0, with a UNIQUE so only one row can exist.
  singleton     Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users                  AppUser[]
  invitations            Invitation[]
  roles                  Role[]
  grants                 Grant[]
  activities             Activity[]
  divisions              Division[]
  teams                  Team[]
  questionnaires         Questionnaire[]
  tasks                  Task[]
  attachments            Attachment[]
  notifications          Notification[]
  integrationConnections IntegrationConnection[]

  @@unique([singleton])
  @@map("organization")
}

model Division {
  id              String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId  String         @map("organization_id") @db.Uuid
  name            String
  defaultOpenings Int            @default(1) @map("default_openings")
  openingsLocked  Boolean        @default(false) @map("openings_locked")
  restrictClaims  Boolean        @default(false) @map("restrict_claims")
  lifecycleState  LifecycleState @default(active) @map("lifecycle_state")
  retiredAt       DateTime?      @map("retired_at") @db.Timestamptz(6)
  version         Int            @default(0)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  // The atomically-created inherent role (kind='division'); UNIQUE role.division_id.
  inherentRole Role?
  // The division's default questionnaire (0..1); UNIQUE questionnaire.owner_division_id.
  questionnaire Questionnaire?
  tasks         Task[]

  @@index([organizationId])
  @@map("division")
}

model Team {
  id             String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  name           String
  restrictClaims Boolean        @default(false) @map("restrict_claims")
  lifecycleState LifecycleState @default(active) @map("lifecycle_state")
  retiredAt      DateTime?      @map("retired_at") @db.Timestamptz(6)
  version        Int            @default(0)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  inherentRole Role?
  tasks        Task[]

  @@index([organizationId])
  @@map("team")
}

model AppUser {
  id                      String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId          String         @map("organization_id") @db.Uuid
  email                   String?        @db.Text // ALTERed to citext in migration
  displayName             String         @map("display_name")
  createdViaInvitationId  String?        @map("created_via_invitation_id") @db.Uuid
  lifecycleState          LifecycleState @default(active) @map("lifecycle_state")
  deactivatedAt           DateTime?      @map("deactivated_at") @db.Timestamptz(6)
  retiredAt               DateTime?      @map("retired_at") @db.Timestamptz(6)
  version                 Int            @default(0)
  createdAt               DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  identities          UserIdentity[]
  sessions            Session[]
  userRoles           UserRole[]
  authTokens          AuthToken[]
  invitationUses      InvitationUse[]
  requestedTasks      Task[]
  taskClaimants       TaskClaimant[]
  submissions         Submission[]
  messages            Message[]
  attachments         Attachment[]
  notifications       Notification[]
  externalIdentities  ExternalIdentity[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("app_user")
}

model UserIdentity {
  id              String       @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  provider        AuthProvider
  providerSubject String?      @map("provider_subject")
  passwordHash    String?      @map("password_hash")
  verifiedAt      DateTime?    @map("verified_at") @db.Timestamptz(6)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  user AppUser @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([provider, providerSubject])
  @@unique([userId, provider])
  @@map("user_identity")
}

model Session {
  id               String     @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId           String     @map("user_id") @db.Uuid
  tokenHash        String     @unique @map("token_hash")
  authMethod       AuthMethod @map("auth_method")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt       DateTime   @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  absoluteExpiresAt DateTime  @map("absolute_expires_at") @db.Timestamptz(6)
  idleExpiresAt    DateTime   @map("idle_expires_at") @db.Timestamptz(6)
  revokedAt        DateTime?  @map("revoked_at") @db.Timestamptz(6)
  ip               String?    @db.Inet
  userAgent        String?    @map("user_agent")

  user AppUser @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@map("session")
}

model Invitation {
  id              String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  tokenHash       String    @unique @map("token_hash")
  email           String?   @db.Text // ALTERed to citext in migration
  intendedRoleIds String[]  @map("intended_role_ids") @db.Uuid
  passcodeHash    String?   @map("passcode_hash")
  maxUses         Int       @default(1) @map("max_uses")
  useCount        Int       @default(0) @map("use_count")
  createdBy       String?   @map("created_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  uses         InvitationUse[]

  @@index([organizationId])
  @@map("invitation")
}

model InvitationUse {
  id            String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  invitationId  String   @map("invitation_id") @db.Uuid
  createdUserId String   @map("created_user_id") @db.Uuid
  usedAt        DateTime @default(now()) @map("used_at") @db.Timestamptz(6)

  invitation  Invitation @relation(fields: [invitationId], references: [id], onDelete: Restrict)
  createdUser AppUser    @relation(fields: [createdUserId], references: [id], onDelete: Restrict)

  @@index([invitationId])
  @@map("invitation_use")
}

model AuthToken {
  id         String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId     String        @map("user_id") @db.Uuid
  kind       AuthTokenKind
  tokenHash  String        @unique @map("token_hash")
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt  DateTime      @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime?     @map("consumed_at") @db.Timestamptz(6)

  user AppUser @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@map("auth_token")
}

model Role {
  id             String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  name           String
  kind           RoleKind
  divisionId     String?        @unique @map("division_id") @db.Uuid
  teamId         String?        @unique @map("team_id") @db.Uuid
  lifecycleState LifecycleState @default(active) @map("lifecycle_state")
  retiredAt      DateTime?      @map("retired_at") @db.Timestamptz(6)
  version        Int            @default(0)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  userRoles       UserRole[]
  grants          Grant[]
  groupMappings   ExternalGroupMapping[]
  // Inherent-role back-relations: an inherent role points at its division/team.
  division        Division?              @relation(fields: [divisionId], references: [id], onDelete: Restrict)
  team            Team?                  @relation(fields: [teamId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@map("role")
}

model UserRole {
  id                 String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId             String         @map("user_id") @db.Uuid
  roleId             String         @map("role_id") @db.Uuid
  source             UserRoleSource @default(patrice)
  sourceConnectionId String?        @map("source_connection_id") @db.Uuid
  grantedBy          String?        @map("granted_by") @db.Uuid
  grantedAt          DateTime       @default(now()) @map("granted_at") @db.Timestamptz(6)
  updatedAt          DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user AppUser @relation(fields: [userId], references: [id], onDelete: Restrict)
  role Role    @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_role")
}

model Grant {
  id               String      @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId   String      @map("organization_id") @db.Uuid
  roleId           String      @map("role_id") @db.Uuid
  action           String
  effect           GrantEffect @default(permit)
  scopeKind        ScopeKind   @map("scope_kind")
  scopeDivisionId  String?     @map("scope_division_id") @db.Uuid
  scopeTeamId      String?     @map("scope_team_id") @db.Uuid
  scopeRoleId      String?     @map("scope_role_id") @db.Uuid
  lifecycleState   LifecycleState @default(active) @map("lifecycle_state")
  retiredAt        DateTime?   @map("retired_at") @db.Timestamptz(6)
  version          Int         @default(0)
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([roleId])
  @@map("grant")
}

model Activity {
  id                 String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId     String         @map("organization_id") @db.Uuid
  actorUserId        String?        @map("actor_user_id") @db.Uuid
  subjectType        String         @map("subject_type")
  subjectId          String         @map("subject_id") @db.Uuid
  verb               String
  payload            Json
  source             ActivitySource
  sourceConnectionId String?        @map("source_connection_id") @db.Uuid
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([subjectType, subjectId, createdAt])
  @@index([createdAt])
  @@map("activity")
}

/// The always-present "ask" a task carries (Slice 3). A questionnaire is owned by
/// **exactly one** of a division (the default) or a task (a per-task copy, Slice 4).
/// Ownership exclusivity is schema-enforced (each owner column UNIQUE + a CHECK that
/// exactly one is non-null — both hand-applied in the migration). `owner_task_id` is
/// a bare column for now; its FK to `task` lands in Slice 4 with the task table.
model Questionnaire {
  id              String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  ownerDivisionId String?  @unique @map("owner_division_id") @db.Uuid
  ownerTaskId     String?  @unique @map("owner_task_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  ownerDivision Division?    @relation(fields: [ownerDivisionId], references: [id], onDelete: Restrict)
  ownerTask     Task?        @relation(fields: [ownerTaskId], references: [id], onDelete: Restrict)
  questions     Question[]

  @@index([organizationId])
  @@map("questionnaire")
}

/// One typed prompt in a questionnaire. `ordinal` orders the set (UNIQUE per
/// questionnaire); `constraints` is the per-type quality bag (numeric range,
/// options, allowed filetypes, char limits) — shape validated at the API boundary.
/// Children of their questionnaire aggregate: ON DELETE CASCADE so a PUT can
/// rewrite the question set in place.
model Question {
  id              String       @id @default(dbgenerated("uuidv7()")) @db.Uuid
  questionnaireId String       @map("questionnaire_id") @db.Uuid
  ordinal         Int
  type            QuestionType
  prompt          String
  required        Boolean      @default(false)
  constraints     Json         @default("{}")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  questionnaire Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  answers       Answer[]

  @@unique([questionnaireId, ordinal])
  @@index([questionnaireId])
  @@map("question")
}

/// A unit of work (Slice 4). Created in a division (optionally a team), it deep-copies
/// the division's default questionnaire into its own `questionnaire` row (reached via
/// the inverse `questionnaire.owner_task_id` — there is no `task.questionnaire_id`).
/// `status_cache` is the rolled-up status (Slice 4: open|claimed). Metadata edits go
/// through PATCH (name/description only); authority/structure changes via named actions.
model Task {
  id              String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId  String         @map("organization_id") @db.Uuid
  name            String
  description     String         @default("") @db.Text
  divisionId      String         @map("division_id") @db.Uuid
  teamId          String?        @map("team_id") @db.Uuid
  requesterUserId String         @map("requester_user_id") @db.Uuid
  openings        Int            @default(1)
  claimsClosed    Boolean        @default(false) @map("claims_closed")
  statusCache     StatusCache?   @map("status_cache")
  lifecycleState  LifecycleState @default(active) @map("lifecycle_state")
  retiredAt       DateTime?      @map("retired_at") @db.Timestamptz(6)
  version         Int            @default(0)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  division     Division       @relation(fields: [divisionId], references: [id], onDelete: Restrict)
  team         Team?          @relation(fields: [teamId], references: [id], onDelete: Restrict)
  requester    AppUser        @relation(fields: [requesterUserId], references: [id], onDelete: Restrict)
  // The task's own questionnaire copy (0..1); UNIQUE questionnaire.owner_task_id.
  questionnaire Questionnaire?
  claimants     TaskClaimant[]
  submissions   Submission[]
  messages      Message[]

  @@index([divisionId])
  @@index([teamId])
  @@index([statusCache])
  @@index([requesterUserId])
  @@index([organizationId])
  @@map("task")
}

/// A claimant slot on a task (Slice 4.2). A user occupies a slot from `joined_at`
/// until `left_at` (NULL = active). UNIQUE(task_id,user_id) keeps a user to at most
/// one slot per task; re-claiming after leaving reactivates the same row. Eligibility
/// to claim is decided in Cedar (`task:assign @ own_as_claimant`), never here.
model TaskClaimant {
  id           String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  taskId       String    @map("task_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  joinedAt     DateTime  @default(now()) @map("joined_at") @db.Timestamptz(6)
  hasSubmitted Boolean   @default(false) @map("has_submitted")
  leftAt       DateTime? @map("left_at") @db.Timestamptz(6)

  task Task    @relation(fields: [taskId], references: [id], onDelete: Restrict)
  user AppUser @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
  @@map("task_claimant")
}

/// A message on a task's thread (Slice 4.3). `comment` messages are user-authored
/// (markdown, optional attachments); senderless `system` messages are emitted for
/// claim/leave/requester-change events. Threads are **one level deep**: a reply sets
/// `parent_message_id` to a TOP-LEVEL message — a DB trigger + app guard reject a
/// reply-to-reply. `submission_id` is a bare column until its FK lands in Slice 5.
model Message {
  id              String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  taskId          String         @map("task_id") @db.Uuid
  kind            MessageKind    @default(comment)
  senderUserId    String?        @map("sender_user_id") @db.Uuid
  parentMessageId String?        @map("parent_message_id") @db.Uuid
  submissionId    String?        @map("submission_id") @db.Uuid
  body            String         @db.Text
  lifecycleState  LifecycleState @default(active) @map("lifecycle_state")
  retiredAt       DateTime?      @map("retired_at") @db.Timestamptz(6)
  editedAt        DateTime?      @map("edited_at") @db.Timestamptz(6)
  version         Int            @default(0)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  task     Task      @relation(fields: [taskId], references: [id], onDelete: Restrict)
  sender   AppUser?  @relation(fields: [senderUserId], references: [id], onDelete: Restrict)
  parent   Message?  @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: Restrict)
  replies  Message[] @relation("MessageThread")
  // A system message hosting a submission's thread (Slice 5); NULL on comments and
  // on task-level audit messages (e.g. the retire-submission audit, which survives GC).
  submission  Submission?  @relation(fields: [submissionId], references: [id], onDelete: Restrict)
  attachments Attachment[]

  @@index([taskId, createdAt])
  @@index([parentMessageId])
  @@index([submissionId])
  @@map("message")
}

/// A claimant's answers to the task's questionnaire (Slice 5), versioned across
/// resubmissions by `submission_no` (part of identity — never changes after insert).
/// `version` is the separate optimistic-lock counter: `task:review` writes are
/// version-guarded and return 409 STALE_SUBMISSION on a lost update. `prev_submission_id`
/// chains a resubmission to the returned version it supersedes.
model Submission {
  id               String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  taskId           String          @map("task_id") @db.Uuid
  claimantUserId   String          @map("claimant_user_id") @db.Uuid
  submissionNo     Int             @map("submission_no")
  prevSubmissionId String?         @map("prev_submission_id") @db.Uuid
  state            SubmissionState @default(review)
  submittedAt      DateTime        @default(now()) @map("submitted_at") @db.Timestamptz(6)
  reviewedBy       String?         @map("reviewed_by") @db.Uuid
  reviewedAt       DateTime?       @map("reviewed_at") @db.Timestamptz(6)
  lifecycleState   LifecycleState  @default(active) @map("lifecycle_state")
  retiredAt        DateTime?       @map("retired_at") @db.Timestamptz(6)
  version          Int             @default(0)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  task            Task         @relation(fields: [taskId], references: [id], onDelete: Restrict)
  claimant        AppUser      @relation(fields: [claimantUserId], references: [id], onDelete: Restrict)
  prevSubmission  Submission?  @relation("SubmissionChain", fields: [prevSubmissionId], references: [id], onDelete: Restrict)
  nextSubmissions Submission[] @relation("SubmissionChain")
  answers         Answer[]
  messages        Message[]

  @@unique([taskId, claimantUserId, submissionNo])
  @@index([taskId])
  @@index([claimantUserId])
  @@map("submission")
}

/// One answer in a submission — a scalar `value` (text/number/choice, as jsonb) and/or
/// referenced attachments (via `attachment.answer_id`). Children of their submission
/// aggregate (ON DELETE CASCADE) so a hard-delete of the submission collects them.
model Answer {
  id           String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  submissionId String   @map("submission_id") @db.Uuid
  questionId   String   @map("question_id") @db.Uuid
  value        Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  submission  Submission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question    Question     @relation(fields: [questionId], references: [id], onDelete: Restrict)
  attachments Attachment[]

  @@index([submissionId])
  @@map("answer")
}

/// An uploaded file (Slice 4.3), stored via the StoragePort (S3 or local-fs) and
/// referenced from EXACTLY ONE of a message (`message_id`) or an answer (`answer_id`,
/// its FK arriving in Slice 5) — a CHECK enforces the exactly-one rule. `storage_key`
/// locates the blob in the configured store; metadata (filename/type/size/checksum)
/// is captured at upload. Download is ungated in v1.
model Attachment {
  id             String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  messageId      String?        @map("message_id") @db.Uuid
  answerId       String?        @map("answer_id") @db.Uuid
  uploaderUserId String         @map("uploader_user_id") @db.Uuid
  storageKey     String         @map("storage_key") @db.Text
  filename       String
  contentType    String         @map("content_type")
  byteSize       BigInt         @map("byte_size")
  kind           AttachmentKind @default(other)
  checksum       String?
  lifecycleState LifecycleState @default(active) @map("lifecycle_state")
  retiredAt      DateTime?      @map("retired_at") @db.Timestamptz(6)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  message      Message?     @relation(fields: [messageId], references: [id], onDelete: Restrict)
  answer       Answer?      @relation(fields: [answerId], references: [id], onDelete: Restrict)
  uploader     AppUser      @relation(fields: [uploaderUserId], references: [id], onDelete: Restrict)

  @@index([messageId])
  @@index([answerId])
  @@index([organizationId])
  @@map("attachment")
}

/// A per-recipient awareness row (Slice 6). One notification is inserted per
/// recipient when a domain event fires; the recipient cohort is resolved and
/// **snapshotted** into `payload` at event time (never re-resolved at delivery).
/// `event_seq` is monotonic per `(subject_type, subject_id, type)` and, with the
/// UNIQUE below, makes insertion **idempotent** — a retry carrying the same
/// `(recipient_user_id, type, subject_id, event_seq)` collides and no-ops. The
/// `payload` carries IDs + small denormalized facts only (Activity Payload
/// Discipline): never PII strings. SSE delivery rides a thin "sync" ping; the
/// durable row is always pulled from here, never from the stream.
model Notification {
  id              String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  recipientUserId String    @map("recipient_user_id") @db.Uuid
  type            String
  subjectType     String    @map("subject_type")
  subjectId       String    @map("subject_id") @db.Uuid
  payload         Json      @default("{}")
  eventSeq        BigInt    @map("event_seq")
  readAt          DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  recipient    AppUser      @relation(fields: [recipientUserId], references: [id], onDelete: Restrict)

  @@unique([recipientUserId, type, subjectId, eventSeq])
  @@index([recipientUserId, readAt, createdAt])
  @@index([organizationId])
  @@map("notification")
}

/// A connection to an external provider (Slice 8). `credentials_ref` is a seam
/// for provider credentials — never custodied here, auth is delegated to the
/// provider. `status` tracks live health; `lifecycle_state` tracks retirement.
model IntegrationConnection {
  id                  String              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId      String              @map("organization_id") @db.Uuid
  provider            IntegrationProvider
  externalWorkspaceId String              @map("external_workspace_id")
  displayName         String              @map("display_name")
  config              Json                @default("{}")
  credentialsRef      String?             @map("credentials_ref")
  status              IntegrationStatus   @default(active)
  lifecycleState      LifecycleState      @default(active) @map("lifecycle_state")
  retiredAt           DateTime?           @map("retired_at") @db.Timestamptz(6)
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  externalIds    ExternalIdentity[]
  groupMappings  ExternalGroupMapping[]

  @@unique([organizationId, provider, externalWorkspaceId])
  @@index([organizationId])
  @@map("integration_connection")
}

/// Links a Patrice user to their external provider account (Slice 8.2). This is
/// an **integration link only** — never an authentication path. `user_identity`
/// is the sole auth path. On user scrub/GC, these rows are purged first.
model ExternalIdentity {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  connectionId   String    @map("connection_id") @db.Uuid
  externalUserId String    @map("external_user_id")
  externalHandle String?   @map("external_handle")
  linkedAt       DateTime  @default(now()) @map("linked_at") @db.Timestamptz(6)
  lastSyncedAt   DateTime? @map("last_synced_at") @db.Timestamptz(6)

  user       AppUser               @relation(fields: [userId], references: [id], onDelete: Restrict)
  connection IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Restrict)

  @@unique([connectionId, externalUserId])
  @@unique([userId, connectionId])
  @@index([userId])
  @@map("external_identity")
}

/// Maps a Patrice role to an external group (e.g. Discord role) within a
/// connection (Slice 8.3). `external_group_id` is a stable provider snowflake,
/// surviving renames. `is_broken` is set when the external group is deleted.
model ExternalGroupMapping {
  id              String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  roleId          String        @map("role_id") @db.Uuid
  connectionId    String        @map("connection_id") @db.Uuid
  externalGroupId String        @map("external_group_id")
  syncDirection   SyncDirection @map("sync_direction")
  isBroken        Boolean       @default(false) @map("is_broken")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  role       Role                  @relation(fields: [roleId], references: [id], onDelete: Restrict)
  connection IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Restrict)

  @@unique([roleId, connectionId, externalGroupId])
  @@index([connectionId])
  @@map("external_group_mapping")
}
